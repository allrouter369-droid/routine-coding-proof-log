{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allrouter.ai/schemas/fingerprint-report-0.1.json",
  "title": "AllRouter Public Fingerprint Report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "collected_at",
    "endpoint_label",
    "declared_model",
    "test_set_version",
    "metrics",
    "limitations"
  ],
  "properties": {
    "schema_version": {"const": "allrouter-fingerprint-report/0.1"},
    "run_id": {"type": "string"},
    "collected_at": {"type": "string", "format": "date-time"},
    "endpoint_label": {"type": "string"},
    "declared_model": {"type": ["string", "null"]},
    "test_set_version": {"type": "string"},
    "verdict": {
      "enum": ["match", "uncertain", "mismatch", "insufficient", null]
    },
    "confidence_note": {"type": "string"},
    "metrics": {
      "type": "object",
      "properties": {
        "mean_jsd": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "comparable_cells": {"type": ["integer", "null"], "minimum": 0},
        "split_half_jsd": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    },
    "reproduction": {"type": "object"},
    "limitations": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    }
  }
}

